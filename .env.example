# Root .env — used by docker-compose.yml
# Copy to .env and add your API key before running: docker compose up --build

# JWT Secret (MUST change in production)
JWT_SECRET_KEY=change-this-to-a-random-secret

# LLM Provider: "groq", "openai", or "mock"
LLM_PROVIDER=groq

# Groq API Key (get free at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (alternative — uncomment and set key)
# OPENAI_API_KEY=sk-your-key-here
