# Backend environment variables
# Copy to .env and update values before running

# Application
APP_NAME=AI Sales Teammate Workbench
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Database (Docker defaults)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sales_workbench
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/sales_workbench

# Redis
REDIS_URL=redis://redis:6379/0

# JWT (MUST change in production)
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AI / LLM — Options: "groq", "openai", or "mock"
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (alternative)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Rate Limiting
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGENERATE=10/minute
RATE_LIMIT_DEFAULT=60/minute

# Background Job
JOB_PROCESSING_DELAY_SECONDS=3
